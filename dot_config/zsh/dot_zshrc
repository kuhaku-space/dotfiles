function is_dirty() {
  test -n "$(chezmoi git -- status --porcelain)"
}

function warn_dirty() {
  if is_dirty; then
    echo -e "\e[1;36m[[dotfiles]]\e[m"
    echo -e "\e[1;33m[warn] DIRTY DOTFILES\e[m"
    echo -e "\e[1;33m    -> Commit your local changes in dotfiles\e[m"
  fi
}

warn_dirty

# apt / mise / dotfiles をまとめて更新する
function update() {
  if command -v apt >/dev/null 2>&1; then
    echo -e "\e[1;36m[update] apt\e[m"
    sudo apt update -qq &&
      sudo apt upgrade -qq -y &&
      sudo apt autoremove -qq -y &&
      sudo apt autoclean -qq -y &&
      sudo apt clean -qq -y
  fi

  if command -v mise >/dev/null 2>&1; then
    echo -e "\e[1;36m[update] mise\e[m"
    mise self-update -y && mise upgrade && mise prune
  fi

  if command -v chezmoi >/dev/null 2>&1; then
    echo -e "\e[1;36m[update] dotfiles (chezmoi)\e[m"
    chezmoi update
  fi
}

eval "$(mise activate zsh)"
eval "$(sheldon source)"

ssh-add -l 2>/dev/null | grep -q 'SHA256' || eval $(keychain --eval --nogui --quiet --agents ssh ~/.ssh/id_ed25519 ~/.ssh/signing-key)

setopt auto_cd
setopt hist_ignore_all_dups
setopt nonomatch

bindkey '^ ' autosuggest-accept

bindkey ' ' zeno-auto-snippet
bindkey '^]' zeno-ghq-cd
bindkey '^r' zeno-history-selection
bindkey '^x' zeno-insert-snippet
